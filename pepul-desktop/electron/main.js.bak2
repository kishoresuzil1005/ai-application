/* --------------------------
   CREATE PROJECT
-------------------------- */
ipcMain.handle("create-project", async (_, data) => {
  try {
    const projectName = (data.wireflow && data.wireflow.projectName) || "generated-app";
    const root = path.join(data.folder, projectName.replace(/\s+/g, "-").toLowerCase());
    if (!fs.existsSync(root)) fs.mkdirSync(root, { recursive: true });

    const sourceCode = await aiManager.askAI(
      "You are an expert software engineer. Return ONLY valid JSON.",
      JSON.stringify(data, null, 2),
      "code"
    );

    let parsed;
    try {
      parsed = JSON.parse(extractJsonString(sourceCode));
    } catch (parseError) {
      console.error("Invalid JSON from code generation:", sourceCode.substring(0, 500));
      throw new Error(`Invalid JSON: ${parseError.message}`);
    }

    for (const file of parsed.files) {
      const filePath = path.join(root, file.path);
      fs.mkdirSync(path.dirname(filePath), { recursive: true });
      fs.writeFileSync(filePath, file.content);
    }

    return { success: true, root };
  } catch (error) {
    console.error(error);
    return { success: false, error: error.message };
  }
});

/* --------------------------
   WORKSPACE FILES
-------------------------- */
ipcMain.handle("get-workspace-files", async () => {
  try {
    const workspace = path.join(process.cwd(), "data");
    if (!fs.existsSync(workspace)) return [];
    return fs.readdirSync(workspace);
  } catch (error) {
    console.error(error);
    return [];
  }
});

/* --------------------------
   GIT STATUS
-------------------------- */
ipcMain.handle("get-git-status", async () => ({
  branch: "main",
  modifiedFiles: [],
  staged: [],
}));

/* --------------------------
   EDITOR
-------------------------- */
ipcMain.handle("read-file", async (_, filePath) => {
  try {
    return fs.readFileSync(filePath, "utf-8");
  } catch (error) {
    console.error(error);
    return "";
  }
});

ipcMain.handle("write-file", async (_, filePath, content) => {
  try {
    fs.mkdirSync(path.dirname(filePath), { recursive: true });
    fs.writeFileSync(filePath, content);
    return { success: true };
  } catch (error) {
    console.error(error);
    return { success: false, error: error.message };
  }
});

ipcMain.handle("search-files", async (_, query) => {
  try {
    const workspace = path.join(process.cwd(), "data");
    if (!fs.existsSync(workspace)) return [];
    return fs.readdirSync(workspace).filter((f) => f.toLowerCase().includes(query.toLowerCase()));
  } catch (error) {
    console.error(error);
    return [];
  }
});

/* --------------------------
   AGENT CHAT
-------------------------- */
ipcMain.handle("ask-agent", async (_, { messages, currentFile, model }) => {
  try {
    const provider = model?.provider || aiConfig.chatProvider;
    const modelId = model?.model || aiConfig.chatModel;
    const result = await aiManager.askAI(
      "You are a Senior Software Engineer helping with code.",
      JSON.stringify({ messages, currentFile }, null, 2),
      "chat",
      { provider, model: modelId }
    );
    return { success: true, data: result };
  } catch (error) {
    return { success: false, error: error.message };
  }
});

