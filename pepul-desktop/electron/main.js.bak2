require("dotenv").config();
require("./database/init");

const {
  app,
  BrowserWindow,
  dialog,
  ipcMain,
} = require("electron");

const path = require("path");
const fs = require("fs");

const aiManager = require("./services/aiManager");
const aiConfig = require("./config/aiConfig");
const groq = require("./services/groq");

function createWindow() {
  const win = new BrowserWindow({
    width: 1600,
    height: 900,
    backgroundColor: "#0f1117",
    webPreferences: {
      preload: path.join(__dirname, "preload.js"),
      contextIsolation: true,
      nodeIntegration: false,
    },
  });

  const port = process.env.NEXT_PORT || 3000;
  win.loadURL(`http://localhost:${port}`);
  if (process.env.NODE_ENV === "development") {
    win.webContents.openDevTools();
  }
}

app.whenReady().then(() => {
  createWindow();
  app.on("activate", () => {
    if (BrowserWindow.getAllWindows().length === 0) createWindow();
  });
});

app.on("window-all-closed", () => {
  if (process.platform !== "darwin") app.quit();
});

/* --------------------------
   OPEN FOLDER
-------------------------- */
ipcMain.handle(
  "open-folder",
  async () => {
    const result = await dialog.showOpenDialog({
      properties: ["openDirectory"],
    });
    if (result.canceled) return null;
    return result.filePaths[0];
  }
);

/* --------------------------
   AI MODEL MANAGEMENT
-------------------------- */
ipcMain.handle("get-ai-model", async () => ({ ...aiConfig }));
ipcMain.handle("set-ai-model", async (_, { provider, model, domain }) => {
  if (!provider || !model) throw new Error("provider and model are required");
  if (domain === "code") {
    aiConfig.codeProvider = provider;
    aiConfig.codeModel = model;
  } else if (domain === "chat") {
    aiConfig.chatProvider = provider;
    aiConfig.chatModel = model;
  } else {
    aiConfig.provider = provider;
    aiConfig.model = model;
  }
  return true;
});

/* --------------------------
   WIREFLOW
-------------------------- */
ipcMain.handle("generate-wireflow", async (_, prompt) => {
  try {
    const result = await aiManager.askAI(
      "You are a Senior UX Architect. Return ONLY valid JSON.",
      prompt,
      "wireflow"
    );
    return { success: true, data: result };
  } catch (error) {
    console.error(error);
    return { success: false, error: error.message };
  }
});

